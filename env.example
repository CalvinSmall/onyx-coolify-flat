# Onyx Lite - Environment Variables for Coolify
# Copy this to .env and configure in Coolify UI
# https://github.com/onyx-dot-app/onyx/tree/main/deployment/docker_compose

# =============================================================================
# REQUIRED VARIABLES - Must be set before deployment
# =============================================================================

# Onyx version (use 'latest' for newest)
IMAGE_TAG=latest

# Authentication - Generate with: openssl rand -hex 32
# REQUIRED: API server will not start without this
USER_AUTH_SECRET=

# Encryption - Generate with: openssl rand -hex 32
# REQUIRED: API server will not start without this
ENCRYPTION_KEY_SECRET=

# Database credentials
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# Domain configuration
WEB_DOMAIN=https://your-domain.com
DOMAIN=your-domain.com

# =============================================================================
# OPTIONAL VARIABLES - Can be left as defaults
# =============================================================================

# Authentication type (basic, google_oauth, oidc, saml)
AUTH_TYPE=basic

# Logging level (debug, info, warning, error)
LOG_LEVEL=info

# Nginx proxy timeouts (seconds)
NGINX_PROXY_CONNECT_TIMEOUT=300
NGINX_PROXY_SEND_TIMEOUT=300
NGINX_PROXY_READ_TIMEOUT=300

# Host port for nginx (Coolify may override this)
HOST_PORT=3000

# =============================================================================
# LLM CONFIGURATION
# Configure your LLM provider in the Onyx UI after deployment
# Or set these environment variables:
# =============================================================================

# Example for OpenAI
# GEN_AI_API_KEY=sk-...
# GEN_AI_MODEL_PROVIDER=openai
# GEN_AI_MODEL_NAME=gpt-4o

# Example for Anthropic
# GEN_AI_API_KEY=sk-ant-...
# GEN_AI_MODEL_PROVIDER=anthropic
# GEN_AI_MODEL_NAME=claude-sonnet-4-20250514

# Example for Ollama (self-hosted)
# GEN_AI_MODEL_PROVIDER=ollama
# GEN_AI_MODEL_NAME=llama3.1
# MODEL_SERVER_HOST=host.docker.internal

# =============================================================================
# ADVANCED SETTINGS - Do not modify unless needed
# =============================================================================

# Lite mode settings (DO NOT CHANGE)
DISABLE_VECTOR_DB=true
FILE_STORE_BACKEND=postgres
CACHE_BACKEND=postgres
AUTH_BACKEND=postgres
DISABLE_MODEL_SERVER=true

# Internal service URLs (managed by Docker Compose)
INTERNAL_URL=http://api_server:8080
POSTGRES_HOST=relational_db

# =============================================================================
# GENERATE SECRETS BEFORE DEPLOYMENT
# Run these commands and copy the output to variables above:
# =============================================================================
# USER_AUTH_SECRET:
#   openssl rand -hex 32
#
# ENCRYPTION_KEY_SECRET:
#   openssl rand -hex 32
#
# POSTGRES_PASSWORD:
#   openssl rand -base64 32
# =============================================================================
